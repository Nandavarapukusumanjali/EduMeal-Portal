rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Hardened helper primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\- ]+$');
    }

    // Retrieve user authority info
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function hasUserRecord() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function hasRole(roleName) {
      return isSignedIn() && hasUserRecord() && getUserRole() == roleName;
    }

    function isAdmin() {
      return (isSignedIn() && request.auth.token != null && 'email' in request.auth.token && request.auth.token.email.matches('^.*_admin@edumeal\\.gov\\.in$')) || hasRole('admin');
    }

    function isCoordinator() {
      return (isSignedIn() && request.auth.token != null && 'email' in request.auth.token && request.auth.token.email.matches('^.*_coordinator@edumeal\\.gov\\.in$')) || hasRole('coordinator');
    }

    function isTeacher() {
      return (isSignedIn() && request.auth.token != null && 'email' in request.auth.token && request.auth.token.email.matches('^.*_teacher@edumeal\\.gov\\.in$')) || hasRole('teacher');
    }

    function isSupervisor() {
      return (isSignedIn() && request.auth.token != null && 'email' in request.auth.token && request.auth.token.email.matches('^.*_supervisor@edumeal\\.gov\\.in$')) || hasRole('supervisor');
    }

    function isStudent() {
      return (isSignedIn() && request.auth.token != null && 'email' in request.auth.token && request.auth.token.email.matches('^.*_student@edumeal\\.gov\\.in$')) || hasRole('student');
    }

    // Rules matching individual collections
    match /users/{userId} {
      allow read: if true;
      allow create, update: if isSignedIn() && (request.auth.uid == userId || isAdmin() || isCoordinator());
      allow delete: if isSignedIn() && (isAdmin() || isCoordinator());
    }

    match /students/{studentId} {
      allow read, list: if true;
      allow create, update, delete: if isSignedIn() && (isTeacher() || isAdmin() || isCoordinator()) && isValidId(studentId);
    }

    match /attendance/{attendanceId} {
      allow read, list: if isSignedIn();
      allow create, update, delete: if isSignedIn() && (isTeacher() || isAdmin() || isCoordinator()) && isValidId(attendanceId);
    }

    match /feedback/{feedbackId} {
      allow read, list: if isSignedIn();
      allow create: if isSignedIn() && isValidId(feedbackId);
      allow update, delete: if isSignedIn() && (isAdmin() || isCoordinator());
    }

    match /wastage/{wastageId} {
      allow read, list: if isSignedIn();
      allow create, update, delete: if isSignedIn() && (isSupervisor() || isAdmin() || isCoordinator()) && isValidId(wastageId);
    }

    match /menu/{menuId} {
      allow read, list: if isSignedIn();
      allow create, update, delete: if isSignedIn() && (isSupervisor() || isAdmin() || isCoordinator());
    }

    match /approvals/{requestId} {
      allow read, list: if isSignedIn() && (isAdmin() || isCoordinator());
      allow create, update, delete: if isSignedIn() && (isAdmin() || isCoordinator()) && isValidId(requestId);
    }

    match /auditLogs/{logId} {
      allow read, list: if isSignedIn() && (isAdmin() || isCoordinator());
      allow create: if isSignedIn() && isValidId(logId);
    }

    match /timetables/{document=**} {
      allow read, list: if isSignedIn() && (isTeacher() || isAdmin() || isCoordinator());
      allow create, update, delete: if isSignedIn() && (isAdmin() || isCoordinator());
    }

    match /test/{testId} {
      allow read: if true;
    }

    // Global Catch-all safety net (Default Deny)
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
