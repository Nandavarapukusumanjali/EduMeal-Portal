{
  "entities": {
    "User": {
      "title": "User",
      "description": "Information about registered portal users and their access roles",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique identifier for authentication" },
        "email": { "type": "string", "description": "User email address" },
        "name": { "type": "string", "description": "Display name / username" },
        "role": { "type": "string", "enum": ["student", "teacher", "supervisor", "admin", "coordinator"], "description": "Role-based access level" },
        "status": { "type": "string", "enum": ["active", "inactive"], "description": "Current account status" },
        "first_login": { "type": "boolean", "description": "Whether this is user's first login" },
        "created_by": { "type": "string", "description": "UID of the user who created this account" },
        "approved_by": { "type": "string", "description": "UID of the admin who approved this account" },
        "approved_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" },
        "assigned_class": { "type": "string", "description": "Teacher's assigned class" },
        "assigned_section": { "type": "string", "description": "Teacher's assigned section" },
        "class": { "type": "string", "description": "Student's class" },
        "section": { "type": "string", "description": "Student's section" },
        "roll_number": { "type": "string", "description": "Student's roll number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Student": {
      "title": "Student",
      "description": "Student roster record managed by teachers",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique student identifier" },
        "name": { "type": "string", "description": "Student full name" },
        "rollNo": { "type": "string", "description": "Student roll number" },
        "class": { "type": "string", "description": "School class level" },
        "section": { "type": "string", "description": "Class section assignment" },
        "gender": { "type": "string", "enum": ["Male", "Female"] },
        "present": { "type": "boolean", "description": "Today's dynamic attendance mark" }
      },
      "required": ["id", "name", "class", "section", "gender", "present"]
    },
    "Attendance": {
      "title": "Attendance",
      "description": "Attendance logs recorded by teachers per day and class",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string" },
        "classStr": { "type": "string" },
        "section": { "type": "string" },
        "totalStudents": { "type": "integer" },
        "totalPresent": { "type": "integer" },
        "totalAbsent": { "type": "integer" },
        "attendancePercentage": { "type": "number" }
      },
      "required": ["id", "date", "classStr", "section", "totalStudents", "totalPresent", "totalAbsent", "attendancePercentage"]
    },
    "Feedback": {
      "title": "Feedback",
      "description": "Mid-day meal quality ratings and comments submitted by student diners",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string" },
        "studentName": { "type": "string" },
        "itemRatings": { "type": "object", "description": "Map of food item names to integer ratings (1-5)" },
        "serviceRatings": {
          "type": "object",
          "properties": {
            "taste": { "type": "integer" },
            "quality": { "type": "integer" },
            "temperature": { "type": "integer" },
            "behaviour": { "type": "integer" },
            "cleanliness": { "type": "integer" }
          }
        },
        "comments": { "type": "string" }
      },
      "required": ["id", "date", "itemRatings", "serviceRatings"]
    },
    "Wastage": {
      "title": "Wastage",
      "description": "Daily food preparation leftovers and wastage audited by supervisor",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string" },
        "items": { "type": "array" },
        "avgWastePercentage": { "type": "number" },
        "mostWastedItem": { "type": "string" },
        "mostWastedQty": { "type": "number" }
      },
      "required": ["id", "date", "items", "avgWastePercentage", "mostWastedItem", "mostWastedQty"]
    },
    "Menu": {
      "title": "Menu",
      "description": "Mid-day meal master schedules including nutrition and tagging",
      "type": "object",
      "properties": {
        "day": { "type": "string" },
        "items": { "type": "array" },
        "calories": { "type": "string" },
        "protein: ": { "type": "string" },
        "fiber": { "type": "string" },
        "veggieTag": { "type": "string" },
        "image": { "type": "string" }
      },
      "required": ["day", "items"]
    },
    "ApprovalRequest": {
      "title": "ApprovalRequest",
      "description": "Administrative action request requiring Principal approval",
      "type": "object",
      "properties": {
        "request_id": { "type": "string" },
        "request_type": { "type": "string" },
        "requested_by": { "type": "string" },
        "request_data": { "type": "object" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "principal_remarks": { "type": "string" },
        "approved_by": { "type": "string" },
        "approved_at": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["request_id", "request_type", "requested_by", "request_data", "status", "createdAt"]
    },
    "AuditLog": {
      "title": "AuditLog",
      "description": "System audit logs for tracking actions",
      "type": "object",
      "properties": {
        "log_id": { "type": "string" },
        "user_id": { "type": "string" },
        "action": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "remarks": { "type": "string" }
      },
      "required": ["log_id", "user_id", "action", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Users credentials and authority profile definitions"
    },
    "/students/{studentId}": {
      "schema": "Student",
      "description": "Student roster registrations"
    },
    "/attendance/{attendanceId}": {
      "schema": "Attendance",
      "description": "Daily attendance logs compiled per class"
    },
    "/feedback/{feedbackId}": {
      "schema": "Feedback",
      "description": "Student ratings and reviews submissions"
    },
    "/wastage/{wastageId}": {
      "schema": "Wastage",
      "description": "Supervisor leftovers and cooking weights logs"
    },
    "/menu/{menuId}": {
      "schema": "Menu",
      "description": "Master dishes dynamic weekly menu"
    },
    "/approvals/{requestId}": {
      "schema": "ApprovalRequest",
      "description": "Approval request registry for principal review"
    },
    "/auditLogs/{logId}": {
      "schema": "AuditLog",
      "description": "System-wide activity audits"
    }
  }
}
